# AWS EC2 Environment Configuration
# 
# Configure your AWS credentials here for local testing.
# WARNING: Never commit this file with real credentials to version control!

# AWS Credentials
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# AWS Region
AWS_REGION=us-east-1

# Optional: S3 bucket for SSM command output
# SSM_OUTPUT_S3_BUCKET=my-ssm-output-bucket
